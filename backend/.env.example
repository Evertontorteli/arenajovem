PORT=3333
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Postgres (Neon). Preferir a connection string COM pooler em produção:
# host no formato ep-xxxx-pooler.region.aws.neon.tech
# Cole a DATABASE_URL do Neon/Vercel (Storage > Neon > .env).
# Enquanto DATABASE_URL estiver preenchida, DB_HOST/DB_PORT sao ignorados.
DATABASE_URL=

# Limite de conexões por instância (Vercel serverless: 3–5 é o ideal)
DB_POOL_MAX=4

# Cache curto do usuário na auth (ms). Default 45000.
AUTH_USER_CACHE_TTL_MS=45000

# Alternativa a DATABASE_URL para desenvolvimento local com Postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=arena_jovem
# Defina como true para forçar SSL quando usar DB_HOST/DB_PORT
DB_SSL=false

JWT_SECRET=troque-esta-chave
JWT_EXPIRES_IN=7d
CURSOR_SECRET=troque-esta-chave-de-cursor
CURSOR_TTL_SECONDS=3600
AUTH_BYPASS_PASSWORD=false
AUTH_LOGIN_RATE_LIMIT_WINDOW_MS=600000
AUTH_LOGIN_RATE_LIMIT_MAX=20
GOOGLE_CLIENT_ID=
DEFAULT_ADMIN_NAME=Administrador Arena Jovem
DEFAULT_ADMIN_EMAIL=admin@arenajovem.com
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_TEST_NAME=Usuario Teste
DEFAULT_TEST_EMAIL=teste@arenajovem.com
DEFAULT_TEST_PASSWORD=teste
RESEND_API_KEY=
# Domínio verificado no Resend — o endereço não precisa existir como caixa de e-mail
EMAIL_FROM=Arena Jovem <noreply@adbelemjales.com>
